{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "builds": [
    {
      "src": "dist-vercel/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist-vercel/**/*"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist-vercel/api/index.js"
    }
  ]
}
